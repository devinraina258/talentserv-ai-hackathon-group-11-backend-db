# Copy to .env and set your key from https://console.x.ai
GROK_API_KEY=your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-1212

# Attach Grok suggestions to every tool/resource response (1=on, 0=off)
GROK_ENRICH_OUTPUTS=1

# SQLite database path (relative to repo root)
DATABASE_PATH=data/employees.db
