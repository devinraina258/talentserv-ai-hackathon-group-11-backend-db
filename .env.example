# Grok via Puter (default) — https://developer.puter.com/tutorials/free-unlimited-grok-api/
# Copy auth token from https://puter.com/dashboard
GROK_PROVIDER=puter
PUTER_AUTH_TOKEN=your_puter_auth_token_here
GROK_API_URL=https://api.puter.com/puterai/openai/v1
GROK_MODEL=x-ai/grok-4.3

# Or direct x.ai (requires console credits): GROK_PROVIDER=xai and GROK_API_KEY
# GROK_API_KEY=your_grok_api_key_here
# GROK_API_URL=https://api.x.ai/v1
# GROK_MODEL=grok-4.3

# Legacy; Grok suggestions are always attached to tool/resource responses
GROK_ENRICH_OUTPUTS=1

# SQLite database path (relative to repo root)
DATABASE_PATH=data/employees.db

# Teams Incoming Webhook
# Example: set a pre-authorized "Incoming Webhook" URL from Microsoft Teams.
TEAMS_WEBHOOK_URL=https://talentservemail.webhook.office.com/webhookb2/597d86b6-2224-44f7-96e1-00bca9e65857@a3494f45-b4e2-4a4e-a4c9-057f42a0332f/IncomingWebhook/9cb6e502666a45b2afc7861c3fc92397/b70bff22-e56f-428d-a987-15a3b830c6e1/V2yTAIQnULDanCWl90Eh8gaeB_ZC1suJt_cgpGmj0op0E1
TEAMS_WEBHOOK_TIMEOUT_SECONDS=5
# Optional: send Adaptive Cards instead of plain text ("1"/"true")
TEAMS_USE_ADAPTIVE_CARD=0
# Optional: notify manager via a separate webhook.
# If set, we will post "Manager notification: ..." to this webhook in addition
# to the normal TEAMS_WEBHOOK_URL.
TEAMS_MANAGER_WEBHOOK_URL=
# Optional: map department -> manager webhook. Overrides TEAMS_MANAGER_WEBHOOK_URL when present.
# Example: TEAMS_MANAGER_WEBHOOK_URL_BY_DEPARTMENT={"Engineering":"https://...","Product":"https://..."}
TEAMS_MANAGER_WEBHOOK_URL_BY_DEPARTMENT=

# Twilio WhatsApp Sandbox — https://www.twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# E.164 phone -> employee slug (devin, nisha, gautam)
WHATSAPP_PHONE_MAP={"+14155550100":"devin","+14155550101":"nisha"}
# Local dev only: set to 1 to skip signature check (never in production)
# TWILIO_SKIP_SIGNATURE=1
# WHATSAPP_HOST=0.0.0.0
# WHATSAPP_PORT=8000
