{
  "mcpServers": {
    "office-leave": {
      "command": "${workspaceFolder}${/}.cursor${/}bin${/}office-leave-mcp${/}run",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_PATH": "data/employees.db",
        "OFFICE_LEAVE_WORKSPACE": "${workspaceFolder}"
      }
    },
    "graphify": {
      "command": "${workspaceFolder}${/}.cursor${/}bin${/}graphify-mcp${/}run",
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  }
}
