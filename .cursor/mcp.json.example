{
  "mcpServers": {
    "office-leave": {
      "command": "python",
      "args": [
        "${workspaceFolder}${/}scripts${/}mcp_launcher.py",
        "-m",
        "src.server"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_PATH": "data/employees.db"
      }
    },
    "graphify": {
      "command": "python",
      "args": [
        "${workspaceFolder}${/}scripts${/}mcp_launcher.py",
        "-m",
        "graphify.serve",
        "${workspaceFolder}${/}graphify-out${/}graph.json"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}
